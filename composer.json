{
    "name": "genvoris/laravel",
    "description": "Official Laravel package for Genvoris Virtual Try-On",
    "type": "library",
    "keywords": [
        "genvoris",
        "virtual-try-on",
        "vton",
        "laravel",
        "ai",
        "fashion",
        "ecommerce"
    ],
    "homepage": "https://docs.genvoris.org",
    "license": "MIT",
    "authors": [
        {
            "name": "Genvoris",
            "email": "support@genvoris.org",
            "homepage": "https://genvoris.org"
        }
    ],
    "support": {
        "email": "support@genvoris.org",
        "docs": "https://docs.genvoris.org",
        "issues": "https://github.com/genvoris/laravel/issues",
        "source": "https://github.com/genvoris/laravel"
    },
    "require": {
        "php": "^8.1",
        "illuminate/cache": "^10.0|^11.0|^12.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0",
        "mockery/mockery": "^1.6",
        "laravel/pint": "^1.0",
        "guzzlehttp/guzzle": "^7.8"
    },
    "autoload": {
        "psr-4": {
            "Genvoris\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Genvoris\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Genvoris\\Laravel\\GenvorisServiceProvider"
            ],
            "aliases": {
                "Genvoris": "Genvoris\\Laravel\\Facades\\Genvoris"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "lint": "vendor/bin/pint",
        "lint:check": "vendor/bin/pint --test"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "policy": {
            "advisories": {
                "block": false
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
